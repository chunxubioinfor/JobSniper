# Secrets — never commit API keys or passwords
.env

# Private files — CVs contain personal information
CVs/

# Runtime data — regenerated daily by the pipeline
data/

# Logs — generated by the pipeline
logs/

# Python bytecode — auto-generated when Python runs your code
__pycache__/
*.pyc

# Virtual environment — installed packages, not source code
venv/

# macOS system files
.DS_Store
