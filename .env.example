# =============================================================================
# JobSniper — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit .env to Git — it contains secrets!
# =============================================================================

# --- LLM Proxy (OpenAI-compatible API) ---
# Used to score jobs against your CV. Supports any OpenAI-compatible proxy.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://globalai.vip/v1
LLM_MODEL=gpt-4o

# --- Apify (LinkedIn job scraping) ---
APIFY_API_TOKEN=your_apify_token_here

# --- Supabase (job storage — shared with job-tracker web app) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
USER_ID=your_supabase_user_uuid_here

# --- Gmail (daily digest email) ---
GMAIL_SENDER=your@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here
GMAIL_RECIPIENT=your@gmail.com
